GPIO4.associatedPins[5].$name            = "Relay_Key_2";
GPIO4.associatedPins[5].direction        = "INPUT";
GPIO4.associatedPins[5].interruptEn      = true;
GPIO4.associatedPins[5].polarity         = "RISE_FALL";
