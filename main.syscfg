GPIO2.$name                              = "AD7606";
GPIO2.port                               = "PORTB";
GPIO2.associatedPins.create(3);
GPIO2.associatedPins[0].internalResistor = "PULL_UP";
GPIO2.associatedPins[0].interruptEn      = true;
GPIO2.associatedPins[0].direction        = "INPUT";
GPIO2.associatedPins[0].$name            = "Busy";
GPIO2.associatedPins[0].polarity         = "FALL";
GPIO2.associatedPins[0].assignedPin      = "4";
GPIO2.associatedPins[1].$name            = "REST";
GPIO2.associatedPins[1].internalResistor = "PULL_UP";
GPIO2.associatedPins[1].pin.$assign      = "PB0";
GPIO2.associatedPins[2].$name            = "CS";
GPIO2.associatedPins[2].internalResistor = "PULL_UP";
GPIO2.associatedPins[2].pin.$assign      = "PB17";

GPIO3.$name                              = "AD9834";
GPIO3.associatedPins.create(2);
GPIO3.associatedPins[0].$name            = "SYNC";
GPIO3.associatedPins[0].internalResistor = "PULL_UP";
